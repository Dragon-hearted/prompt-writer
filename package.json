{
	"name": "adcelerate-prompt-writer",
	"version": "0.1.0",
	"type": "module",
	"description": "Centralized prompt engineering knowledge system with per-model guides, visual direction references, and a model registry for AI image, video, and voice generation",
	"bin": {
		"prompt-writer": "./src/cli.ts"
	},
	"scripts": {
		"dev": "bun run --watch src/index.ts",
		"build": "bun build src/index.ts --outdir dist --target bun",
		"test": "bun test",
		"lint": "bunx @biomejs/biome check .",
		"check": "bunx @biomejs/biome check --write ."
	},
	"dependencies": {
		"js-yaml": "^4.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/bun": "latest",
		"@types/js-yaml": "^4.0.9",
		"typescript": "^5.7.0"
	}
}
